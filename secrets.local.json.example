{
  "_comment": "Copy to secrets.local.json (git-ignored) and fill in YOUR secrets. The server reads this file into memory only and NEVER emits the values — the agent, cache, logs, and dashboard receive a [WHISKOR_REDACTED ...] token instead. Requires privacy.secretGuard.enabled=true in config.json. 'type' chooses the agent-visible hint: email exposes only the domain; password/token expose no hint. Add an optional 'ref' to let the agent type a value it can't see via the type_secret tool (the agent passes the ref name, never the value). Values shorter than 3 chars are ignored.",
  "secrets": [
    { "ref": "user_email",    "value": "you@gmail.com",            "type": "email" },
    { "ref": "user_password", "value": "your-actual-password",     "type": "password" },
    { "ref": "api_token",     "value": "sk-live-xxxxxxxxxxxxxxxx", "type": "token" }
  ]
}
