{
  "_comment": "Copy to secrets.local.json (git-ignored) and fill in YOUR secrets. The server reads this file into memory only and NEVER emits the values — the agent, cache, logs, and dashboard receive a [WHISKOR_REDACTED ...] token instead. Requires privacy.secretGuard.enabled=true in config.json. 'type' chooses the agent-visible hint: email exposes only the domain; password/token expose no hint. Values shorter than 3 chars are ignored (false-positive guard).",
  "secrets": [
    { "value": "you@gmail.com", "type": "email" },
    { "value": "your-actual-password", "type": "password" },
    { "value": "sk-live-xxxxxxxxxxxxxxxx", "type": "token" }
  ]
}
