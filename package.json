{
  "name": "browser-whiskor",
  "version": "0.10.1",
  "description": "Agent-grade browser instrumentation with MCP server",
  "license": "MIT",
  "homepage": "https://github.com/torotoroTRPG/browser-whiskor#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/torotoroTRPG/browser-whiskor.git"
  },
  "bugs": {
    "url": "https://github.com/torotoroTRPG/browser-whiskor/issues"
  },
  "main": "server/index.js",
  "bin": {
    "whk": "./server/cli.js",
    "whiskor": "./server/cli.js"
  },
  "scripts": {
    "start": "node scripts/supervisor.js",
    "start:raw": "node server/index.js",
    "mcp": "node server/index.js --mcp",
    "verbose": "node server/index.js --verbose",
    "mock": "node server/index.js --mock",
    "stop": "pwsh -NoProfile -File scripts/stop.ps1",
    "restart": "pwsh -NoProfile -File scripts/restart.ps1",
    "setup": "pwsh -NoProfile -File scripts/setup.ps1",
    "test": "node scripts/_run-tests.js tests/unit tests/integration tests/stress",
    "test:unit": "node scripts/_run-tests.js tests/unit",
    "test:integration": "node scripts/_run-tests.js tests/integration",
    "test:stress": "node scripts/_run-tests.js tests/stress",
    "test:coverage": "node scripts/_run-tests.js --coverage tests/unit tests/integration tests/stress",
    "test:e2e": "npx playwright test tests/e2e/",
    "download-model": "node scripts/download-model.js",
    "check-version": "node scripts/_check-version.js",
    "check-config": "node scripts/_check-config-defaults.js",
    "check-tests": "node scripts/_check-hollow-tests.js",
    "sync-version": "node scripts/_check-version.js --fix",
    "version": "node scripts/_check-version.js --fix && git add extension/manifest.json firefox-mv2/manifest.json"
  },
  "dependencies": {
    "ws": "^8.18.0",
    "@xenova/transformers": "^2.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "playwright": "^1.60.0"
  }
}
