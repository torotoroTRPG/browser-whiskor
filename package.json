{
  "name": "browser-whiskor",
  "version": "0.5.2",
  "description": "Agent-grade browser instrumentation with MCP server",
  "main": "server/index.js",
  "scripts": {
    "start": "node server/index.js",
    "mcp": "node server/index.js --mcp",
    "verbose": "node server/index.js --verbose",
    "mock": "node server/index.js --mock",
    "stop": "pwsh -NoProfile -File scripts/stop.ps1",
    "restart": "pwsh -NoProfile -File scripts/restart.ps1",
    "test": "node --test tests/unit/ tests/integration/ tests/stress/",
    "test:unit": "node --test tests/unit/",
    "test:integration": "node --test tests/integration/",
    "test:stress": "node --test tests/stress/",
    "test:coverage": "node --test --experimental-test-coverage tests/unit/ tests/integration/ tests/stress/",
    "test:e2e": "npx playwright test tests/e2e/",
    "download-model": "node scripts/download-model.js",
    "check-version": "node scripts/_check-version.js",
    "sync-version": "node scripts/_check-version.js --fix",
    "version": "node scripts/_check-version.js --fix && git add extension/manifest.json firefox-mv2/manifest.json"
  },
  "dependencies": {
    "playwright": "^1.60.0",
    "ws": "^8.18.0",
    "@xenova/transformers": "^2.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0"
  }
}
