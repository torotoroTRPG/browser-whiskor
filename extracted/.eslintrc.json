{
  "env": {
    "node": true,
    "es2022": true,
    "browser": true,
    "webextensions": true
  },
  "parserOptions": {
    "ecmaVersion": 2022,
    "sourceType": "script"
  },
  "rules": {
    "no-unused-vars": ["warn", { "args": "none", "caughtErrors": "none" }],
    "no-undef": "error",
    "no-const-assign": "error",
    "no-dupe-keys": "error",
    "no-duplicate-case": "error",
    "no-empty": ["warn", { "allowEmptyCatch": true }],
    "no-func-assign": "error",
    "no-obj-calls": "error",
    "no-unreachable": "error",
    "valid-typeof": "error",
    "curly": ["warn", "multi-line"],
    "eqeqeq": ["warn", "smart"],
    "no-throw-literal": "warn",
    "no-var": "warn",
    "prefer-const": ["warn", { "destructuring": "all" }]
  },
  "globals": {
    "window": "readonly",
    "document": "readonly",
    "chrome": "readonly",
    "browser": "readonly",
    "self": "readonly",
    "globalThis": "readonly"
  }
}
